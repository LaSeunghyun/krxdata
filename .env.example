# OpenDart API
# 발급: https://opendart.fss.or.kr
DART_API_KEY=your_dart_api_key_here

# 공공데이터포털 API
# 발급: https://www.data.go.kr
# 사용 API:
# - 금융위원회_주식시세정보
# - 금융위원회_KRX상장종목정보
# Encoding 인증키를 입력하세요.
PUBLIC_DATA_API_KEY=your_public_data_api_key_here

# Supabase REST upsert
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# Analysis defaults
ANALYSIS_YEAR=2025
ANALYSIS_YEAR_FALLBACK=2024
SCORE_BATCH_SIZE=100
SCORE_DELAY_MS=300
TOP_STOCK_LIMIT=100

# Timeouts and script-specific throttling
FETCH_TIMEOUT_MS=10000
BATCH_TIMEOUT_MS=30000
PATCH_MARKETCAP_DELAY_MS=200
FILTER_DELAY_MS=500
